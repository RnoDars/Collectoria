# Collectoria Deployment Scripts Configuration
# Copy this file to .env.local and customize for your environment

# Project paths
PROJECT_DIR=/home/collectoria/Collectoria
COMPOSE_FILE=${PROJECT_DIR}/docker-compose.prod.yml

# Database configuration
DB_CONTAINER=collectoria-postgres
DB_USER=collectoria
DB_NAME=collectoria

# Backup configuration
BACKUP_DIR=/home/collectoria/backups

# Keep N latest Docker images (for rollback)
KEEP_IMAGES=2

# Remote backup sync (optional)
# REMOTE_BACKUP=user@backup-server:/backups/collectoria/

# Migration configuration
MIGRATIONS_DIR=${PROJECT_DIR}/backend/collection-management/migrations

# Deployment log directory
DEPLOYMENT_LOG_DIR=${PROJECT_DIR}/.deployment/history

# Health check endpoints
BACKEND_HEALTH_URL=http://localhost:8080/api/v1/health
FRONTEND_HEALTH_URL=http://localhost:3000

# External URLs
FRONTEND_URL=https://darsling.fr
BACKEND_URL=https://api.darsling.fr

# Notification settings (future use)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
# EMAIL_ALERTS=admin@example.com
